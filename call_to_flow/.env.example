EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_CALLER_ID=
EXOTEL_REGION=

VOICEBOT_APP_ID=
IVR_APP_ID=

# Optional explicit URLs. If omitted, the backend builds:
# http://my.exotel.com/{EXOTEL_SID}/exoml/start_voice/{APP_ID}
VOICEBOT_FLOW_URL=
IVR_FLOW_URL=

# Optional callback for future CRM/webhook tracking.
EXOTEL_STATUS_CALLBACK_URL=
EXOTEL_CALL_TYPE=trans
EXOTEL_TIMEOUT_SECONDS=30
EXOTEL_TIME_LIMIT_SECONDS=1800
CALL_TO_FLOW_API_BASE=http://localhost:8000

# The root main.py requires a bot argument. Change this for sales demos.
VOICEBOT_START_COMMAND=python main.py --health-bot
VOICEBOT_HOST=127.0.0.1
VOICEBOT_PORT=5000
VOICEBOT_READY_TIMEOUT_SECONDS=20

CORS_ORIGINS=*
