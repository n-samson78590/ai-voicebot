# Voice AI Bot Configuration
# Copy this file to .env and fill in your values

# Required Settings
OPENAI_API_KEY=your-openai-api-key-here
COMPANY_NAME=Your Company Name
SALES_BOT_NAME=SALES_BOT_NAME
HEALTH_BOT_NAME=HEALTH_BOT_NAME

# Optional Settings (defaults provided)
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SAMPLE_RATE=8000
AUDIO_CHUNK_SIZE=200
OPENAI_MODEL=gpt-realtime
OPENAI_VOICE=coral
LOG_LEVEL=INFO